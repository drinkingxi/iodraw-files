uration":10,"end":1780675199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_fk1777341401386_1","name":"确认飞机连接进度，以及ner如何跟当前航班真实数据联动","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"取决于其他团队的飞机连接进度","code":"3.2","level":2,"status":"STATUS_WAITING","depends":"","start":1779638400000,"duration":10,"end":1780675199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_fk1777343121632_1","name":"是否集成efb","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"3.3","level":2,"status":"STATUS_WAITING","depends":"","start":1780848000000,"duration":10,"end":1781884799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_user_testing_parent","name":"用户测试","progress":"0.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"分阶段用户测试，从内部Alpha到全场景商业化试运行","code":4,"level":1,"status":"STATUS_WAITING","depends":"","start":1778428800000,"duration":106,"end":1791215999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_alpha_internal_test","name":"Alpha版本内部封测","progress":0,"progressByWorklog":false,"description":"核心目标：跑通核心技术，确保交到航司手里的东西不能有低级Bug。\n执行：压力测试（高分贝噪音、iPad性能/内存/发热）、UI/UX飞行员场景优化、语音服务器稳定性验证。\n规模：内部团队 + 1-2名飞行员顾问","code":"4.1","level":2,"status":"STATUS_WAITING","depends":"","start":1778428800000,"duration":15,"end":1780070399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"inPeople":""},{"id":"tmp_beta_phase1_ground","name":"阶段一：地面沙盘与模拟机测试","progress":0,"progressByWorklog":false,"description":"目标：验证核心算法能力、端侧稳定性，确保「能用且不添乱」。\n执行：在地面模拟器中验证ASR/NER准确率，测试无网络环境下的端侧性能。\n规模：1-2家航司（国航/厦航），5-10名飞行员参与","code":"4.2","level":2,"status":"STATUS_WAITING","depends":"","start":1780329600000,"duration":15,"end":1782143999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"inPeople":""},{"id":"tmp_beta_phase2_shadow","name":"阶段二：影子模式与跟飞观察","progress":0,"progressByWorklog":false,"description":"目标：观察员验证真实机舱复杂声学环境和无网状态下的表现，不干扰真实机组操作。\n执行：观察员随飞，记录「Say Again」频率、系统误识率、设备发热等真实数据。建立高频反馈通道，保持每日小版本迭代。\n规模：2家航司，10-20名飞行员参与","code":"4.3","level":2,"status":"STATUS_WAITING","depends":"","start":1782144000000,"duration":20,"end":1784563199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"inPeople":""},{"id":"tmp_beta_phase3_noncritical","name":"阶段三：非关键航段辅助运行","progress":0,"progressByWorklog":false,"description":"目标：机长、副机长验证产品的实际业务价值，降低飞行员认知负荷。\n执行：在起飞/巡航等非关键阶段正式辅助使用，采集NASA-TLX认知负荷评分，统计关键参数复诵错误拦截次数。\n规模：2家航司，20-50名飞行员参与","code":"4.4","level":2,"status":"STATUS_WAITING","depends":"","start":1784649600000,"duration":20,"end":1787068799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"inPeople":""},{"id":"tmp_beta_phase4_full","name":"阶段四：全场景试运行与效能评估","progress":0,"progressByWorklog":false,"description":"目标：积累量化数字，证明产品价值，打造标杆案例（Case Study），准备商业化转正。\n执行：全飞行阶段启用，系统采集「Say Again」下降率、复诵错误拦截次数、响应时间缩短等核心指标，形成可用于宣传的数据报告。\n规模：2+家航司，50+名飞行员，覆盖国际航线重口音高密度空域","code":"4.5","level":2,"status":"STATUS_WAITING","depends":"","start":1787155200000,"duration":30,"end":1790783999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"inPeople":""},{"id":"tmp_launch_prep_parent","name":"正式发布准备","progress":"0.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"解决飞行员正式使用的线材、合规性等问题，准备商业化正式发布","code":5,"level":1,"status":"STATUS_WAITING","depends":"","start":1780329600000,"duration":79,"end":1789747199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_hardware_cable","name":"线材与硬件方案确认及采购","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"解决飞行员驾驶舱使用的耳机线连接方案：确认线材规格（航空标准插头适配）、供应商、采购数量及交付时间，确保正式发布时可随产品提供硬件配件","code":"5.1","level":2,"status":"STATUS_WAITING","depends":"","start":1780329600000,"duration":20,"end":1782748799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_compliance_cert","name":"合规性认证准备","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"推进航空电子设备相关合规认证，确认产品满足航司EFB使用规范及CAAC/局方对机载电子设备的合规要求；明确认证路径、所需材料及预计周期","code":"5.2","level":2,"status":"STATUS_WAITING","depends":"","start":1782144000000,"duration":40,"end":1786982399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]},{"id":"tmp_official_launch","name":"产品正式发布","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"完成线材、合规性等问题后，面向飞行员正式商业化发布。发布时携带阶段四积累的量化数据（Say Again下降率、安全拦截次数、NASA-TLX改善等）作为核心宣传素材","code":"5.3","level":2,"status":"STATUS_WAITING","depends":"","start":1791388800000,"duration":1,"end":1791475199999,"startIsMilestone":false,"endIsMilestone":true,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[]}],"selectedRow":28,"deletedTaskIds":[],"canAdd":true,"canWrite":true,"canWriteOnParent":true,"zoom":"1M","satIsHoly":"Y","sunIsHoly":"Y"}